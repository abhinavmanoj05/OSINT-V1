# Application
APP_NAME="Crime Analysis Mapper"
DEBUG=True
ENVIRONMENT=development
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database (Using SQLite for minimal setup)
USE_SQLITE=True

# Neo4j (Update these to match your Neo4j Desktop Instance)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=12345678

# Redis (Bypassed via Celery eager mode, no need to install)
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# =============================================================================
# LLM Comprehension Layer — Ollama (local, no API keys, fully offline)
# =============================================================================
# Provider: ollama | none
# ollama = use local Ollama server (install from https://ollama.ai)
# none   = disable LLM, fall back to regex-only extraction
LLM_PROVIDER=ollama

# Ollama server address (default after install)
OLLAMA_HOST=http://localhost:11434

# Model to use — pull it first with: ollama pull qwen2.5
# Recommended options (in order of preference):
#   qwen2.5          — fast, excellent at structured JSON, great for OSINT (default)
#   qwen2.5:14b      — larger, more capable, needs ~10GB RAM
#   qwen2.5:32b      — most capable, needs ~20GB RAM
#   llama3.1         — Meta's model, solid all-rounder
#   mistral          — fast, good reasoning
#   phi3             — small & fast, good for low-RAM machines
#   gemma2           — Google's open model
# Fixed: use the actually installed model. Run 'ollama list' to see available models.
OLLAMA_MODEL=qwen2.5:3b

# =============================================================================
# MCP Tool Settings (from osint-tools-mcp-server)
# =============================================================================
# SpiderFoot: comprehensive OSINT but takes 5-30 minutes. Use only for formal cases.
USE_SPIDERFOOT=False
# Paths for tools not found in PATH (leave empty if installed globally)
SPIDERFOOT_PATH=
BLACKBIRD_PATH=

# =============================================================================
# New Version MCP OSINT Server (new_version/osint-tools-mcp-server)
# =============================================================================
# Path to the standalone MCP server script (used for Ollama-driven OSINT)
# Leave empty to auto-detect from project root
NEW_VERSION_MCP_SERVER_PATH=
